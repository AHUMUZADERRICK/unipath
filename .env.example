# Database Configuration
POSTGRES_DB=unipath
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Important: POSTGRES_PASSWORD is used by both db and backend services.
# If you change this after Postgres has already initialized a data volume,
# also update the DB user's password (ALTER USER) or recreate the DB volume.

# App Host Ports
BACKEND_PORT=8001
FRONTEND_PORT=3001

# Django Settings
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=your-secret-key-here-generate-something-long-and-random
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,129.121.85.122
CORS_ALLOW_ALL_ORIGINS=1

# Default Admin Bootstrap
DEFAULT_ADMIN_USERNAME=AZD
DEFAULT_ADMIN_PASSWORD=azd123456
DEFAULT_ADMIN_EMAIL=azd@unipath.local

# Firebase (optional migration mode)
USE_FIREBASE=0
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_FILE=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_ADMIN_EMAIL=azd@unipath.local

# Frontend API URL (used during build)
VITE_API_BASE_URL=http://localhost:8001/api
